# Semptify55 - Environment Configuration
# Copy this file to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=true
SECURITY_MODE=open

# Security (generate a strong random string for production)
SECRET_KEY=your-secret-key-here-change-in-production

# Database (Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/semptify55

# Redis (Docker)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# OAuth - Google Drive
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret

# OAuth - Dropbox
# Get credentials at: https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret

# OAuth - OneDrive
# Get credentials at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
ONEDRIVE_CLIENT_ID=your-onedrive-client-id
ONEDRIVE_CLIENT_SECRET=your-onedrive-client-secret

# Admin
ADMIN_EMAIL=your-email@example.com
